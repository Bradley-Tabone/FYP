# =============================================================================
# Android
# =============================================================================
*.iml
.gradle
/local.properties
/.idea/caches
/.idea/libraries
/.idea/modules.xml
/.idea/workspace.xml
/.idea/navEditor.xml
/.idea/assetWizardSettings.xml
.DS_Store
/build
/captures
.externalNativeBuild
.cxx
local.properties

# =============================================================================
# Dataset images — large, re-downloadable from Roboflow
# Labels and COCO JSON annotations are kept (small, version-controlled)
# =============================================================================
ml-training/data/train/images/
ml-training/data/valid/images/
ml-training/data/test/images/

# Label cache files generated by Ultralytics
ml-training/data/**/*.cache

# =============================================================================
# Model weights and exports — too large for GitHub
# val* run directories are kept (confusion matrices, PR curves, CSVs)
# =============================================================================

# PyTorch weights
**/*.pt
**/*.pth

# Export formats
**/*.onnx
**/*.tflite

# RF-DETR run directory (3.6 GB — all training checkpoints)
ml-training/notebooks/runs/rfdetr/

# Weights subdirectories inside each detect run (kept: plots, CSVs, args.yaml)
ml-training/notebooks/runs/detect/*/weights/

# =============================================================================
# Downloaded pretrained model files in project root / notebooks dir
# =============================================================================
ml-training/notebooks/*.pt
ml-training/models/*.pt

# =============================================================================
# Windows / WSL metadata
# =============================================================================
*:Zone.Identifier

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.pyc
*.pyo
.ipynb_checkpoints/

# =============================================================================
# Claude Code session memory (local tooling, not project code)
# =============================================================================
ml-training/.claude/
.claude/
