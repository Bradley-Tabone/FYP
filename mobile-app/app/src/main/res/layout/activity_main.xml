<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Camera preview fills the full screen (visible for developer/testing) -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!--
        Full-screen tap target overlaid on the preview.
        Semi-transparent so the camera feed remains visible during development.
        The blind user only needs TTS + beeping — the button text is secondary.
    -->
    <Button
        android:id="@+id/listenButton"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text="@string/tap_to_speak"
        android:textSize="24sp"
        android:textColor="@android:color/white"
        app:backgroundTint="#99000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
